<view class="ol">
  <view wx:if="{{!list.length}}" class="ol-empty">暂无问诊记录</view>
  <view class="ol-item" wx:for="{{list}}" wx:key="id" bindtap="open" data-i="{{index}}">
    <view class="ol-item__top">
      <text class="ol-item__doc">{{item.doctor_name || '医生'}} <text class="ol-item__dept">{{item.dept || ''}}</text></text>
      <text class="ol-item__st">{{item.statusText}}</text>
    </view>
    <view class="ol-item__mid">
      <text class="ol-item__tag">{{item.typeText}}问诊</text>
      <text class="ol-item__no">订单号 {{item.order_no}}</text>
    </view>
    <view wx:if="{{item.timeText}}" class="ol-item__time" style="color:#9aa3ab;font-size:24rpx;margin-top:6rpx;">{{item.timeText}}</view>
    <view class="ol-item__bot">
      <text class="ol-item__fee">挂号费 ¥{{item.feeYuan}}</text>
      <view class="flex items-center" style="gap:24rpx;">
        <text wx:if="{{item.canEvaluate}}" class="ol-item__eval" catchtap="goEvaluate" data-i="{{index}}">评价</text>
        <text class="ol-item__go">查看 ›</text>
      </view>
    </view>
  </view>
</view>
