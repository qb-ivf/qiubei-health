.chat { display: flex; flex-direction: column; height: 100vh; background: #f4f5f7; }

.chat-list { flex: 1; padding: 24rpx; box-sizing: border-box; }
.chat-empty { text-align: center; color: #909399; font-size: 26rpx; margin-top: 80rpx; }

.chat-row { display: flex; margin-bottom: 24rpx; }
.chat-row--mine { justify-content: flex-end; }

.chat-bubble {
  max-width: 70%; background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx;
  font-size: 30rpx; color: #303133; word-break: break-all;
}
.chat-bubble--mine { background: #0056c4; color: #fff; }
.chat-txt { line-height: 1.5; }
.chat-img { max-width: 360rpx; border-radius: 12rpx; display: block; }

.chat-bar {
  display: flex; align-items: center; gap: 16rpx; padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff; border-top: 1rpx solid #ebeef5;
}
.chat-img-btn { width: 64rpx; display: flex; align-items: center; justify-content: center; }
.chat-input { flex: 1; height: 72rpx; background: #f4f5f7; border-radius: 36rpx; padding: 0 28rpx; font-size: 28rpx; }
.chat-send { background: #0056c4; color: #fff; font-size: 28rpx; padding: 0 32rpx; height: 72rpx; line-height: 72rpx; border-radius: 36rpx; }
