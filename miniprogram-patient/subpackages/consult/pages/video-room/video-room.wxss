.vr { position: relative; width: 100vw; height: 100vh; background: #191b23; overflow: hidden; }
.vr__big { position: absolute; inset: 0; }
.vr__media { width: 100%; height: 100%; }
.vr__placeholder {
  position: absolute; inset: 0; display: flex; flex-direction: column;
  align-items: center; justify-content: center; background: #2e3038;
}

.vr__top {
  position: absolute; top: 0; left: 0; right: 0; z-index: 10;
  display: flex; align-items: flex-start; justify-content: space-between; padding: 16rpx 32rpx;
}
.vr__timer {
  display: flex; align-items: center; gap: 12rpx;
  background: rgba(255,255,255,.85); padding: 10rpx 24rpx; border-radius: 9999rpx;
}
.vr__dot { width: 16rpx; height: 16rpx; border-radius: 9999rpx; background: var(--secondary); }
.vr__timer text { color: var(--on-surface) !important; }
.vr__small {
  position: relative; width: 200rpx; height: 280rpx; border-radius: 24rpx; overflow: hidden;
  border: 4rpx solid rgba(255,255,255,.5); background: var(--surface-variant);
}
.vr__small-ph { position: absolute; bottom: 12rpx; right: 12rpx; background: rgba(0,0,0,.4); border-radius: 6rpx; padding: 2rpx 6rpx; }

.vr__controls { position: absolute; bottom: 0; left: 0; right: 0; z-index: 30; padding: 0 32rpx 64rpx; padding-bottom: calc(64rpx + env(safe-area-inset-bottom)); }
.vr__ctrl-capsule {
  background: rgba(25,27,35,.75); border-radius: 9999rpx;
  padding: 24rpx 40rpx; display: flex; align-items: center; justify-content: space-between;
  border: 1rpx solid rgba(255,255,255,.1);
}
.vr__ctrl { width: 96rpx; height: 96rpx; border-radius: 9999rpx; display: flex; align-items: center; justify-content: center; }
.vr__ctrl--end { width: 120rpx; height: 120rpx; background: var(--error); }
