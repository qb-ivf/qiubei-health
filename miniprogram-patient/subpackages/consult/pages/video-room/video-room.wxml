<!-- 页面5：全屏双向视频诊室（对照 html/video_consultation.html）含步战术3 -->
<view class="vr">
  <!-- 大窗（默认医生 live-player） -->
  <view class="vr__big" bindtap="noop">
    <live-player wx:if="{{!isSwapped}}" class="vr__media" src="{{playerSrc}}" mode="RTC" autoplay sound-mode="speaker" object-fit="fillCrop" bindstatechange="onState"></live-player>
    <live-pusher wx:else class="vr__media" url="{{pusherSrc}}" mode="RTC" autopush enable-camera="{{cameraOn}}" enable-mic="{{micOn}}"></live-pusher>
    <view wx:if="{{!ready}}" class="vr__placeholder">
      <text class="material-symbols-outlined" style="font-size:96rpx;color:rgba(255,255,255,.5);">videocam</text>
      <text class="text-body-sm" style="color:rgba(255,255,255,.6);margin-top:16rpx;">等待视频流接入（联调阶段填入拉流地址）</text>
    </view>
  </view>

  <!-- 顶部状态 -->
  <view class="vr__top" style="padding-top: {{statusBar}}px;">
    <view class="vr__timer">
      <view class="vr__dot"></view>
      <text class="text-label-md text-white">{{timeText}}</text>
    </view>
    <!-- 小窗（点击对调） -->
    <view class="vr__small" bindtap="swap">
      <live-pusher wx:if="{{!isSwapped}}" class="vr__media" url="{{pusherSrc}}" mode="RTC" autopush enable-camera="{{cameraOn}}" enable-mic="{{micOn}}"></live-pusher>
      <live-player wx:else class="vr__media" src="{{playerSrc}}" mode="RTC" autoplay object-fit="fillCrop"></live-player>
      <view class="vr__small-ph"><text class="material-symbols-outlined" style="font-size:28rpx;color:#fff;">videocam</text></view>
    </view>
  </view>

  <!-- 底部控制 -->
  <view class="vr__controls">
    <view class="vr__ctrl-capsule">
      <view class="vr__ctrl" bindtap="toggleMic">
        <text class="material-symbols-outlined" style="font-size:48rpx;color:{{micOn ? '#fff' : 'var(--error)'}};">{{micOn ? 'mic' : 'mic_off'}}</text>
      </view>
      <view class="vr__ctrl" bindtap="toggleCamera">
        <text class="material-symbols-outlined" style="font-size:48rpx;color:{{cameraOn ? '#fff' : 'var(--error)'}};">{{cameraOn ? 'videocam' : 'videocam_off'}}</text>
      </view>
      <view class="vr__ctrl vr__ctrl--end" bindtap="hangup">
        <text class="material-symbols-outlined ms-fill" style="font-size:56rpx;color:#fff;">call_end</text>
      </view>
      <view class="vr__ctrl" bindtap="toggleSpeaker">
        <text class="material-symbols-outlined" style="font-size:48rpx;color:#fff;">{{speakerOn ? 'volume_up' : 'volume_off'}}</text>
      </view>
      <view class="vr__ctrl" bindtap="flip">
        <text class="material-symbols-outlined" style="font-size:48rpx;color:#fff;">flip_camera_ios</text>
      </view>
    </view>
  </view>
</view>
