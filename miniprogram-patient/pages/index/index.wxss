.home { min-height: 100vh; }
.home__body { box-sizing: border-box; height: 100vh; }

.appbar { position: fixed; left: 0; right: 0; top: 0; box-sizing: border-box; }
.patient-pill {
  background: var(--sc-low);
  border: 1rpx solid var(--outline-variant);
  border-radius: 9999rpx;
  padding: 10rpx 22rpx;
}

.queue-bar {
  display: flex; align-items: center; gap: 12rpx;
  margin: 16rpx 32rpx 0; padding: 20rpx 28rpx;
  background: #fff8e1; border: 1rpx solid #ffe08a; border-radius: 16rpx;
}
.queue-bar__txt { font-size: 26rpx; color: #8a6d00; flex: 1; }

.search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 96rpx;
  padding: 0 28rpx;
  background: var(--sc-highest);
  border-radius: 9999rpx;
}

.banner {
  position: relative;
  height: 256rpx;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}
.banner__txt { display: flex; flex-direction: column; z-index: 1; }
.banner__icon { position: absolute; right: 20rpx; bottom: 0; font-size: 200rpx; color: rgba(255, 255, 255, .18); }

.kingkong { display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.kk-video {
  border-radius: 24rpx;
  padding: 32rpx;
  height: 360rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
}
.kk-video__icon { font-size: 128rpx; color: rgba(255, 255, 255, .2); align-self: flex-end; }
.kk-right { display: flex; flex-direction: column; gap: 24rpx; height: 360rpx; }
.kk-cell { flex: 1; border-radius: 24rpx; padding: 32rpx; display: flex; flex-direction: column; justify-content: center; box-sizing: border-box; }

.quick { display: grid; grid-template-columns: repeat(4, 1fr); padding: 32rpx 0; }
.quick__item { display: flex; flex-direction: column; align-items: center; }

.marquee {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--sc-low);
  border-top: 1rpx solid var(--outline-variant);
  border-bottom: 1rpx solid var(--outline-variant);
}
.marquee__txt { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.doc-rail { white-space: nowrap; padding: 0 32rpx 24rpx; }
.doc-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 300rpx;
  padding: 32rpx;
  margin-right: 24rpx;
  box-sizing: border-box;
  vertical-align: top;
}
.doc-card__avatar {
  width: 120rpx; height: 120rpx; border-radius: 9999rpx;
  background: var(--primary-fixed);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16rpx;
}
.doc-card__btn {
  margin-top: 24rpx; width: 100%; text-align: center;
  background: var(--primary-container); color: var(--on-primary-container);
  font-size: 28rpx; font-weight: 600; padding: 12rpx 0; border-radius: 9999rpx;
}
