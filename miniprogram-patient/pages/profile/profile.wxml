<!-- 页面7：个人中心（对照 html/personal_center.html） -->
<view class="pc">
  <!-- Hero -->
  <view class="pc-hero">
    <view class="pc-hero__row">
      <view class="pc-hero__avatar"><text class="material-symbols-outlined" style="font-size:72rpx;color:var(--primary);">account_circle</text></view>
      <view>
        <text class="text-headline-lg text-white">{{user.name}}</text>
        <view class="pc-hero__badge">
          <text class="material-symbols-outlined ms-fill" style="font-size:24rpx;color:#fff;margin-right:6rpx;">verified</text>
          <text class="text-caption text-white">已实名认证</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 当前就诊人卡 -->
  <view class="px-margin-x pc-patient-wrap">
    <view class="card pc-patient">
      <view class="flex flex-col gap-1">
        <view class="flex items-center gap-2">
          <text class="text-label-md text-on-surface-variant">当前就诊人</text>
          <text class="material-symbols-outlined text-primary" style="font-size:28rpx;">account_circle</text>
        </view>
        <text class="text-headline-md text-on-surface">{{user.name}} (自己)</text>
        <text class="text-caption text-on-surface-variant">{{user.idMask}}</text>
      </view>
      <view class="pc-patient__btn" bindtap="goPatients">切换/添加</view>
    </view>
  </view>

  <!-- 我的问诊 -->
  <view class="px-margin-x" style="margin-top:48rpx;">
    <view class="card" style="padding:32rpx;">
      <view class="flex justify-between items-center mb-md" bindtap="goOrders">
        <text class="text-label-lg text-on-surface">我的问诊</text>
        <view class="flex items-center text-on-surface-variant"><text class="text-caption">全部订单</text><text class="material-symbols-outlined" style="font-size:30rpx;">chevron_right</text></view>
      </view>
      <view class="grid grid-cols-4">
        <view class="pc-order" wx:for="{{orders}}" wx:key="t" bindtap="goOrders" data-s="{{item.s}}" data-t="{{item.t}}">
          <view class="pc-order__ic">
            <text class="material-symbols-outlined text-on-surface-variant" style="font-size:44rpx;">{{item.icon}}</text>
            <view wx:if="{{item.badge}}" class="pc-order__badge">{{item.badge}}</view>
          </view>
          <text class="text-caption text-on-surface-variant">{{item.t}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 健康资产 -->
  <view class="px-margin-x" style="margin-top:48rpx;">
    <view class="card pc-list">
      <view class="pc-row" wx:for="{{assets}}" wx:key="t" bindtap="goAsset" data-t="{{item.t}}">
        <view class="flex items-center gap-3">
          <view class="pc-row__ic" style="color:{{item.color}};background:{{item.bg}};"><text class="material-symbols-outlined" style="font-size:40rpx;">{{item.icon}}</text></view>
          <text class="text-body-md text-on-surface">{{item.t}}</text>
        </view>
        <text class="material-symbols-outlined text-outline-variant">chevron_right</text>
      </view>
    </view>
  </view>

  <!-- 支持 -->
  <view class="px-margin-x" style="margin-top:48rpx;padding-bottom:64rpx;">
    <view class="card pc-list">
      <view class="pc-row" bindtap="comingSoon">
        <view class="flex items-center gap-3">
          <view class="pc-row__ic" style="color:var(--on-surface-variant);background:var(--sc);"><text class="material-symbols-outlined" style="font-size:40rpx;">support_agent</text></view>
          <text class="text-body-md text-on-surface">联系客服/在线导诊</text>
        </view>
        <text class="material-symbols-outlined text-outline-variant">chevron_right</text>
      </view>
      <view class="pc-row" bindtap="comingSoon">
        <view class="flex items-center gap-3">
          <view class="pc-row__ic" style="color:var(--on-surface-variant);background:var(--sc);"><text class="material-symbols-outlined" style="font-size:40rpx;">gavel</text></view>
          <text class="text-body-md text-on-surface">隐私政策与用户协议</text>
        </view>
        <text class="material-symbols-outlined text-outline-variant">chevron_right</text>
      </view>
    </view>
  </view>
</view>
