.pc-hero {
  background: linear-gradient(180deg, var(--primary) 0%, var(--primary-fixed) 100%);
  padding: 48rpx 32rpx 128rpx;
}
.pc-hero__row { display: flex; align-items: center; gap: 24rpx; }
.pc-hero__avatar { width: 120rpx; height: 120rpx; border-radius: 9999rpx; background: #fff; border: 4rpx solid rgba(255,255,255,.5); display: flex; align-items: center; justify-content: center; }
.pc-hero__badge { display: inline-flex; align-items: center; margin-top: 12rpx; background: rgba(255,255,255,.2); border: 1rpx solid rgba(255,255,255,.3); padding: 4rpx 16rpx; border-radius: 9999rpx; }

.pc-patient-wrap { margin-top: -96rpx; position: relative; z-index: 2; }
.pc-patient { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; }
.pc-patient__btn { background: rgba(0,86,196,.1); color: var(--primary); padding: 16rpx 32rpx; border-radius: 9999rpx; font-size: 28rpx; font-weight: 600; }

.pc-order { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.pc-order__ic { position: relative; width: 96rpx; height: 96rpx; border-radius: 24rpx; background: var(--sc-low); display: flex; align-items: center; justify-content: center; }
.pc-order__badge { position: absolute; top: -6rpx; right: -6rpx; min-width: 32rpx; height: 32rpx; padding: 0 6rpx; background: var(--error); color: #fff; font-size: 20rpx; border-radius: 9999rpx; display: flex; align-items: center; justify-content: center; border: 2rpx solid #fff; }

.pc-list { padding: 0; overflow: hidden; }
.pc-row { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; border-bottom: 1rpx solid rgba(194,198,215,.2); }
.pc-row:last-child { border-bottom: none; }
.pc-row__ic { width: 64rpx; height: 64rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
