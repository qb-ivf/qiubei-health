.search-box { display: flex; align-items: center; gap: 16rpx; height: 88rpx; padding: 0 28rpx; background: var(--sc-low); border-radius: 24rpx; }
.search-box__input { flex: 1; }
.search-tag { padding: 12rpx 28rpx; background: var(--sc-high); border-radius: 9999rpx; font-size: 28rpx; color: var(--on-surface-variant); }
.search-results { margin-top: 32rpx; display: flex; flex-direction: column; gap: 20rpx; }
.search-result { display: flex; align-items: center; gap: 20rpx; padding: 28rpx; }
.search-empty { display: flex; flex-direction: column; align-items: center; padding-top: 120rpx; }
