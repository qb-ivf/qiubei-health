.search {
  display: flex; align-items: center; gap: 16rpx;
  height: 96rpx; padding: 0 28rpx;
  background: var(--sc-low); border-radius: 24rpx;
}

.dates { white-space: nowrap; background: var(--surface); padding: 16rpx 32rpx; position: sticky; top: 0; z-index: 40; }
.date-chip {
  display: inline-flex; flex-direction: column; align-items: center;
  min-width: 132rpx; padding: 20rpx 0; margin-right: 24rpx;
  border-radius: 24rpx; background: var(--sc-lowest);
  border: 1rpx solid var(--outline-variant); color: var(--on-surface-variant);
  vertical-align: top;
}
.date-chip--active {
  background: var(--primary); color: #fff; border-color: var(--primary);
  box-shadow: 0 8rpx 24rpx rgba(0, 86, 196, .2);
}

.doc-list { display: flex; flex-direction: column; gap: 32rpx; margin-top: 24rpx; }
.doc { display: flex; gap: 24rpx; padding: 32rpx; align-items: flex-start; }
.doc--full { opacity: .7; }
.doc__avatar {
  position: relative; width: 112rpx; height: 112rpx; border-radius: 9999rpx;
  background: var(--primary-fixed); display: flex; align-items: center; justify-content: center;
  border: 2rpx solid var(--primary-fixed); flex-shrink: 0;
}
.doc__dot {
  position: absolute; bottom: -2rpx; right: -2rpx; width: 24rpx; height: 24rpx;
  background: var(--secondary); border: 4rpx solid var(--surface); border-radius: 9999rpx;
}
.doc__main { flex: 1; }
.doc__pro {
  background: var(--primary-fixed); color: var(--on-primary-fixed);
  font-size: 20rpx; font-weight: 700; padding: 2rpx 12rpx; border-radius: 6rpx;
}
.doc__btn {
  height: 88rpx; padding: 0 64rpx; background: var(--primary); color: #fff;
  border-radius: 24rpx; font-size: 32rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, .12);
}
.doc__btn--off { background: var(--outline); opacity: .5; box-shadow: none; }
