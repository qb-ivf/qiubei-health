.pt { padding-top: 24rpx; display: flex; flex-direction: column; gap: 24rpx; }
.pt-item { display: flex; align-items: center; gap: 24rpx; padding: 32rpx; }
.pt-item--active { border-color: var(--primary); }
.pt-item__ic { width: 88rpx; height: 88rpx; border-radius: 9999rpx; background: var(--primary-fixed); display: flex; align-items: center; justify-content: center; }
.pt-item__rel { font-size: 24rpx; color: var(--secondary); border: 1rpx solid var(--secondary); padding: 0 10rpx; border-radius: 6rpx; }
.pt-item__verified { font-size: 24rpx; color: var(--primary); background: var(--primary-fixed); padding: 2rpx 12rpx; border-radius: 6rpx; }
.pt-add { margin-top: 16rpx; height: 104rpx; border: 2rpx dashed var(--outline-variant); border-radius: 24rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; color: var(--primary); font-size: 30rpx; font-weight: 600; }
