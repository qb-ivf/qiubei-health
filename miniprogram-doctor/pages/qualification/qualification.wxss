.q { min-height: 100vh; background: #f4f5f7; padding: 24rpx; box-sizing: border-box; }

.q-status { border-radius: 16rpx; padding: 28rpx 32rpx; margin-bottom: 24rpx; }
.q-status__txt { font-size: 32rpx; font-weight: 700; display: block; }
.q-status__sub { font-size: 26rpx; opacity: .8; margin-top: 8rpx; display: block; }
.q-status--pending { background: #fff7e6; color: #ad6800; }
.q-status--rejected { background: #fff1f0; color: #cf1322; }
.q-status--approved { background: #f6ffed; color: #389e0d; }

.q-pass { padding: 40rpx 0; }

.q-form { background: #fff; border-radius: 16rpx; padding: 32rpx; }
.q-title { font-size: 36rpx; font-weight: 700; color: #0056c4; }
.q-tip { font-size: 24rpx; color: #909399; margin: 12rpx 0 24rpx; }

.q-field { margin-bottom: 24rpx; }
.q-label { font-size: 26rpx; color: #606266; display: block; margin-bottom: 10rpx; }
.q-input {
  height: 80rpx; border: 1rpx solid #dcdfe6; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; background: #fff;
}
.q-textarea {
  width: 100%; min-height: 120rpx; border: 1rpx solid #dcdfe6; border-radius: 12rpx;
  padding: 16rpx 24rpx; font-size: 28rpx; box-sizing: border-box;
}

.q-btn {
  margin-top: 16rpx; height: 88rpx; line-height: 88rpx; border-radius: 44rpx;
  font-size: 30rpx; border: none;
}
.q-btn--primary { background: #0056c4; color: #fff; }

.q-logout { text-align: center; color: #909399; font-size: 26rpx; margin-top: 40rpx; padding: 16rpx; }
