# 复制为 .env 后按需修改（.env 不入库）
APP_NAME=Qiubei SaaS Backend
DEBUG=true

# 数据库（docker-compose 默认值）
DATABASE_URL=mysql+aiomysql://qiubei:qiubei@localhost:3306/qiubei?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT（生产务必替换强密钥）
JWT_SECRET=CHANGE_ME_IN_PROD
JWT_EXPIRE_MINUTES=1440

# 敏感字段加密 Fernet key（生成：python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"）
ENCRYPTION_KEY=

# 微信登录（小程序 AppID/Secret；留空走开发 mock）
WX_PATIENT_APPID=
WX_PATIENT_SECRET=
WX_DOCTOR_APPID=
WX_DOCTOR_SECRET=

# 医生白名单：开发 true（自动通过），生产 false（走 admin 终审）
DOCTOR_AUTO_APPROVE=true

# 腾讯云 TRTC（密钥仅存服务端）
TRTC_SDKAPPID=0
TRTC_SECRETKEY=

# 微信支付
WX_APPID=
WX_MCHID=
WX_API_V3_KEY=

# 合规网关
GOV_REPORT_URL=
GOV_APP_SECRET=
CA_SIGN_URL=
