# 复制为 .env 后按需修改（.env 不入库）
APP_NAME=Qiubei SaaS Backend
DEBUG=true

# 数据库（docker-compose 默认值）
DATABASE_URL=mysql+aiomysql://qiubei:qiubei@localhost:3306/qiubei?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT（生产务必替换强密钥）
JWT_SECRET=CHANGE_ME_IN_PROD
JWT_EXPIRE_MINUTES=1440

# 敏感字段加密 Fernet key（生成：python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"）
ENCRYPTION_KEY=

# 微信登录（小程序 AppID/Secret；留空走开发 mock）
WX_PATIENT_APPID=
WX_PATIENT_SECRET=
WX_DOCTOR_APPID=
WX_DOCTOR_SECRET=

# 医生白名单：开发 true（自动通过），生产 false（走 admin 终审）
DOCTOR_AUTO_APPROVE=true

# CORS 白名单（生产填 admin-web 域名，逗号分隔；空=不允许跨域。小程序不受影响）
CORS_ORIGINS=

# 腾讯云 TRTC（密钥仅存服务端）
TRTC_SDKAPPID=0
TRTC_SECRETKEY=

# 微信支付（商户主体：天津逑贝互联网医院有限公司）
WX_APPID=                    # 发起支付的小程序 AppID（患者端）
WX_MCHID=                    # 商户号
WX_API_V3_KEY=              # APIv3 密钥（32 位）
WX_MCH_CERT_SERIAL=         # 商户 API 证书序列号
WX_MCH_PRIVATE_KEY_PATH=   # 商户私钥路径，如 secrets/apiclient_key.pem
WX_PAY_NOTIFY_URL=         # 支付回调地址（公网 HTTPS），如 https://api.example.com/api/v1/orders/pay/callback；空则走 mock
WX_PAY_PUBLIC_KEY_PATH=    # 微信支付公钥 pub_key.pem 路径（新商户公钥模式回调验签），如 secrets/wx_pay_public_key.pem
WX_PAY_PUBLIC_KEY_ID=      # 微信支付公钥ID（PUB_KEY_ID_...，可选）

# 合规网关
GOV_REPORT_URL=
GOV_APP_SECRET=
CA_SIGN_URL=
