# 复制为 .env 后按需修改（.env 不入库）
APP_NAME=Qiubei SaaS Backend
DEBUG=true

# 数据库（docker-compose 默认值）
DATABASE_URL=mysql+aiomysql://qiubei:qiubei@localhost:3306/qiubei?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT（生产务必替换强密钥）
JWT_SECRET=CHANGE_ME_IN_PROD
JWT_EXPIRE_MINUTES=1440

# 腾讯云 TRTC（密钥仅存服务端）
TRTC_SDKAPPID=0
TRTC_SECRETKEY=

# 微信支付
WX_APPID=
WX_MCHID=
WX_API_V3_KEY=

# 合规网关
GOV_REPORT_URL=
GOV_APP_SECRET=
CA_SIGN_URL=
